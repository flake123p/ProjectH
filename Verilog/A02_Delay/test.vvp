#! c:/iverilog-x86/bin/vvp
:ivl_version "10.0 (stable)" "(v10_0)";
:ivl_delay_selection "TYPICAL";
:vpi_time_precision - 11;
:vpi_module "system";
:vpi_module "vhdl_sys";
:vpi_module "v2005_math";
:vpi_module "va_math";
S_007d5938 .scope module, "simple_tb" "simple_tb" 2 3;
 .timescale -9 -11;
v007d3d90_0 .var "A", 0 0;
v007dfc68_0 .var "B", 0 0;
v007dfcc0_0 .net "O1", 0 0, L_007d3de8;  1 drivers
S_007d3c10 .scope module, "M1" "simple" 2 8, 3 12 0, S_007d5938;
 .timescale -9 -11;
    .port_info 0 /INPUT 1 "IN1"
    .port_info 1 /INPUT 1 "IN2"
    .port_info 2 /OUTPUT 1 "OUT_OR"
L_007d3de8/d .functor OR 1, v007d3d90_0, v007dfc68_0, C4<0>, C4<0>;
L_007d3de8 .delay 1 (2000,2000,2000) L_007d3de8/d;
v007d5a08_0 .net "IN1", 0 0, v007d3d90_0;  1 drivers
v007d3ce0_0 .net "IN2", 0 0, v007dfc68_0;  1 drivers
v007d3d38_0 .net "OUT_OR", 0 0, L_007d3de8;  alias, 1 drivers
    .scope S_007d5938;
T_0 ;
    %vpi_call 2 13 "$dumpfile", "simple.vcd" {0 0 0};
    %vpi_call 2 14 "$dumpvars", 32'sb00000000000000000000000000000000, S_007d3c10 {0 0 0};
    %vpi_call 2 15 "$monitor", "A = %b, B = %b | O1 = %b ", v007d3d90_0, v007dfc68_0, v007dfcc0_0 {0 0 0};
    %pushi/vec4 0, 0, 1;
    %store/vec4 v007d3d90_0, 0, 1;
    %pushi/vec4 0, 0, 1;
    %store/vec4 v007dfc68_0, 0, 1;
    %delay 5000, 0;
    %pushi/vec4 0, 0, 1;
    %store/vec4 v007d3d90_0, 0, 1;
    %pushi/vec4 1, 0, 1;
    %store/vec4 v007dfc68_0, 0, 1;
    %end;
    .thread T_0;
    .scope S_007d5938;
T_1 ;
    %delay 8000, 0;
    %vpi_call 2 21 "$finish" {0 0 0};
    %end;
    .thread T_1;
# The file index is used to find the file name in the following table.
:file_names 4;
    "N/A";
    "<interactive>";
    "test_tb.v";
    "test.v";
